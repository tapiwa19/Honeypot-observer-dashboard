{
  "name": "honeypot-backend",
  "version": "1.0.0",
  "description": "Backend API for Honeypot Observer",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "demo:quick": "node demo/triggerAlert.js",
    "demo:attack": "node demo/simulateSession.js",
    "demo:full": "node demo/fullDemo.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --verbose",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/integration --verbose --testTimeout=15000"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.19.1",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.2",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.1.5",
    "nodemailer": "^9.0.3",
    "socket.io": "^4.8.3",
    "twilio": "^5.12.0"
  },
  "devDependencies": {
    "jest": "^30.4.1",
    "nodemon": "^3.0.2",
    "supertest": "^7.2.2"
  },
  "jest": {
    "transform": {},
    "testEnvironment": "node"
  }
}
